{
  "name": "dorfgefluester-infra",
  "version": "0.1.0",
  "description": "Dorfgeflüster — Helm, ArgoCD, Nginx, Jenkins, infrastructure",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "quality:trivy": "node scripts/quality/trivy-fs-scan.cjs",
    "quality:sonar": "node scripts/quality/sonarqube-export.cjs",
    "quality:sonar:report": "node scripts/quality/sonar-report.cjs",
    "quality:sonar:plan": "node scripts/quality/sonar-plan-export.cjs",
    "quality:pull": "node scripts/quality/pull-findings.cjs",
    "quality-check": "node scripts/quality/run-skill-gate.cjs --mode local",
    "build-skills": "node scripts/build-skills.cjs",
    "hooks:install": "node scripts/setup/install-git-hooks.cjs"
