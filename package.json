      "minimatch": "^3.1.4"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@biomejs/biome": "^2.4.8",
    "@jest/globals": "^30.3.0",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0"
